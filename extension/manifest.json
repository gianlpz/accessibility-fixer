{
  "manifest_version": 3,
  "name": "Access4U",
  "version": "1.0.0",
  "description": "Audit any page for WCAG accessibility violations with one click",
  "permissions": ["activeTab", "contextMenus", "scripting", "sidePanel", "storage"],
  "background": {
    "service_worker": "build/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "build/src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "build/src/sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["axe.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
